{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Baribudos Studio",
  "version": "1.0.0",
  "identifier": "com.baribudos.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Baribudos Studio",
        "width": 1400,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": []
  }
}
