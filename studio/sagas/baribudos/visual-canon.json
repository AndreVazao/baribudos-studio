{
  "ip": "Os Baribudos",
  "author": "André Vazão",
  "produced_by": "Baribudos Studio",
  "age_target": "4-10",

  "visual_dna": {
    "body_shape": "small_round",
    "fur": "short_soft_fluffy",
    "eyes": "big_green_expressive",
    "ears": "small_rounded",
    "nose": "small_round",
    "hands": "4_fingers",
    "feet": "short",
    "eyebrows": "expressive",
    "style_rule": "never_realistic_never_scary"
  },

  "style": {
    "render_style": "cinematic_storybook_watercolor",
    "lighting": "warm_soft_sunlight",
    "atmosphere": "calm_magical_safe",
    "detail_level": "high_soft_edges",
    "shadow_style": "gentle_diffused",
    "realism": "low_cartoon_high_quality"
  },

  "environment": {
    "primary_setting": "enchanted_forest",
    "secondary_elements": [
      "floating_golden_particles",
      "soft_light_through_leaves",
      "peaceful_nature",
      "subtle_magic"
    ],
    "forbidden_elements": [
      "dark_horror",
      "realistic_predators",
      "violent_weather",
      "urban_aggressive"
    ]
  },

  "color_palette": {
    "primary_green": "#2F5E2E",
    "secondary_green": "#6FA86A",
    "gold_accent": "#D4A73C",
    "cream_background": "#F5EED6",
    "brown_nature": "#8B5E3C"
  },

  "lighting_rules": {
    "type": "soft_cinematic",
    "temperature": "warm",
    "magic_glow": "subtle",
    "no_dark_scenes": true
  },

  "illustration_rules": {
    "main_image_per_page": true,
    "text_space_required": true,
    "balanced_layout": true,
    "soft_edges": true,
    "watercolor_digital": true
  },

  "cover_rules": {
    "logo_top": true,
    "age_badge_top_right": true,
    "seal_bottom_left": true,
    "character_center": true,
    "magic_element_visible": true,
    "title_gold": true,
    "studio_credit_bottom": true
  },

  "composition_rules": {
    "single_main_illustration": true,
    "character_visibility_priority": true,
    "text_breathing_space": true,
    "balanced_storybook_layout": true,
    "no_visual_noise": true
  },

  "emotional_tone": [
    "curiosity",
    "gentle_discovery",
    "emotional_learning",
    "calm_wonder"
  ],

  "visual_references": {
    "tone": [
      "pixar_storybook",
      "totoro_soft_magic",
      "bluey_emotional_safety"
    ],
    "note": "reference tone only, never copy"
  }
  }
