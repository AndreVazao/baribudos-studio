{
  "ip": "Os Baribudos",

  "core_identity": {
    "mission": "Histórias que Protegem",
    "purpose": "Desenvolvimento emocional infantil",
    "tone": "calm_safe_educational",
    "world_theme": "nature_as_learning_space",
    "magic_level": "subtle_symbolic"
  },

  "core_mission": "educar emocionalmente crianças através de histórias seguras",

  "tone_rules": {
    "calm": true,
    "educational": true,
    "safe": true,
    "never_scary": true,
    "reflective": true
  },

  "forbidden_elements": [
    "explicit_violence",
    "realistic_horror",
    "death_trauma",
    "aggressive_conflict",
    "punishment_fear",
    "dark_psychology"
  ],

  "narrative_structure_standard": [
    "simple_introduction",
    "strange_element_or_problem",
    "emotional_questioning",
    "gentle_guidance_or_reflection",
    "progressive_transformation",
    "implicit_moral",
    "final_strong_sentence"
  ],

  "episode_structure_standard": [
    "curiosity_event",
    "temptation_or_doubt",
    "warning_signal",
    "conscious_decision",
    "family_conversation",
    "practical_moral"
  ],

  "story_rules": {
    "no_explicit_violence": true,
    "threat_symbolic": true,
    "family_resolution": true,
    "safe_ending": true,
    "child_empowerment": true
  },

  "language_style": {
    "sentence_length": "short",
    "vocabulary": "simple",
    "emotional_clarity": true,
    "reflection_encouraged": true
  },

  "emotional_learning_focus": [
    "safety_awareness",
    "self_decision",
    "trust_discernment",
    "emotional_intelligence",
    "family_support"
  ],

  "values_pool": [
    "responsibility",
    "sharing",
    "courage",
    "patience",
    "self_protection",
    "nature_care",
    "critical_thinking",
    "trust_awareness"
  ],

  "main_characters_roles": {
    "Magnus": "rational_explainer",
    "Luma": "emotional_support",
    "Roko": "growth_conflict",
    "Mila": "intuitive_questioning",
    "Tilo": "innocent_learning"
  },

  "villains_symbolic": [
    {
      "name": "Criatura Encapuzada",
      "represents": "manipulation"
    },
    {
      "name": "Eco da Floresta",
      "represents": "dangerous_secrets"
    },
    {
      "name": "Névoa Doce",
      "represents": "tempting_offers"
    },
    {
      "name": "Caminho Fácil",
      "represents": "unsafe_shortcuts"
    }
  ],

  "family_resolution_rule": true,
  "decision_focus_rule": true,
  "lesson_always_present": true,

  "final_phrase_rule": {
    "enabled": true,
    "default_phrase": "Na dúvida, escolhe o caminho seguro."
  },

  "episode_duration_target_minutes": 5,
  "audiobook_duration_target_minutes": 6,

  "story_page_structure": {
    "max_lines": 5,
    "simple_language": true,
    "centered_text": true
  }
    }
